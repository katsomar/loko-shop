# ----------------------------------------------------------------------
# Web Application Security & Routing Config
# Optimized for Apache / InfinityFree
# ----------------------------------------------------------------------

# 1. Disable directory listing (Indexes)
# Commented out because InfinityFree blocks this directive and throws a 500 error.
# (InfinityFree disables directory indexes by default on their servers anyway).
# Options -Indexes

# 2. Set the default index file
DirectoryIndex index.php

# 3. Enable Rewrite Engine
RewriteEngine On

# 4. Block access to sensitive directories (Defense in Depth)
RewriteRule ^(backups|config|cron|database|includes|logs|migrations|sql|vendor|\.git|\.qodo)(/|$) - [F,L]

# 5. Prevent access to sensitive files
<FilesMatch "\.(sql|zip|json|lock|md|log|sh|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# 6. Clean URLs: Support extension-less URLs (e.g. /auth/signup instead of /auth/signup.php)
# If the request is not a directory, and the request path + ".php" exists as a file, rewrite to it.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L,QSA]
